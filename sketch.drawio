<mxfile host="app.diagrams.net" agent="Codex" version="24.7.17" compressed="false"><diagram id="sender-fsm" name="Sender FSM"><mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="st" value="Sender FSM — uart_sender.v" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#002060;" vertex="1" parent="1"><mxGeometry x="50" y="30" width="700" height="50" as="geometry"/></mxCell><mxCell id="s0" value="&lt;b&gt;IDLE&lt;/b&gt;&lt;br&gt;tx = 1&lt;br&gt;index = 0&lt;br&gt;busy = 0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#CCFFCC;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="80" y="330" width="210" height="160" as="geometry"/></mxCell><mxCell id="s1" value="&lt;b&gt;START&lt;/b&gt;&lt;br&gt;data latched&lt;br&gt;wait for tx_en" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFF99;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="440" y="330" width="210" height="160" as="geometry"/></mxCell><mxCell id="s2" value="&lt;b&gt;DATA&lt;/b&gt;&lt;br&gt;tx = data[index]&lt;br&gt;LSB first" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D9E1F2;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="800" y="330" width="210" height="160" as="geometry"/></mxCell><mxCell id="s3" value="&lt;b&gt;STOP&lt;/b&gt;&lt;br&gt;wait for tx_en&lt;br&gt;then tx = 1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE2D5;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="1160" y="330" width="210" height="160" as="geometry"/></mxCell><mxCell id="se0" value="wr_en / data &lt;= data_in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="s0" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="se1" value="tx_en / tx &lt;= 0, index &lt;= 0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="se2" value="tx_en &amp;&amp; index == 7 / tx &lt;= data[7]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="se3" value="tx_en / tx &lt;= 1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="s3" target="s0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="se4" value="tx_en &amp;&amp; index &lt; 7 / index++" style="edgeStyle=orthogonalEdgeStyle;loopDirection=1;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;" edge="1" parent="1" source="s2" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="sn" value="busy is combinational: state != IDLE. In this implementation it falls when the stop bit starts, not after the stop interval." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7D6;strokeColor=#E9C84A;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="420" y="650" width="680" height="90" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="receiver-fsm" name="Receiver FSM"><mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="rt" value="Receiver FSM — uart_receiver.v" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#002060;" vertex="1" parent="1"><mxGeometry x="50" y="30" width="780" height="50" as="geometry"/></mxCell><mxCell id="r0" value="&lt;b&gt;IDLE&lt;/b&gt;&lt;br&gt;sample = 0&lt;br&gt;index = 0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#CCFFCC;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="70" y="340" width="210" height="160" as="geometry"/></mxCell><mxCell id="r1" value="&lt;b&gt;START&lt;/b&gt;&lt;br&gt;validate low at&lt;br&gt;sample == 7" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFF99;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="430" y="340" width="210" height="160" as="geometry"/></mxCell><mxCell id="r2" value="&lt;b&gt;DATA&lt;/b&gt;&lt;br&gt;sample temp[index]&lt;br&gt;at sample == 15" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D9E1F2;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="790" y="340" width="210" height="160" as="geometry"/></mxCell><mxCell id="r3" value="&lt;b&gt;STOP&lt;/b&gt;&lt;br&gt;check rx at&lt;br&gt;sample == 15" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE2D5;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="1150" y="340" width="210" height="160" as="geometry"/></mxCell><mxCell id="re0" value="rx_en &amp;&amp; rx == 0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="r0" target="r1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="re1" value="sample == 7 &amp;&amp; rx == 0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="re2" value="sample == 15 &amp;&amp; index == 7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="re3" value="sample == 15 / valid stop: data_out &lt;= temp, rdy &lt;= 1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="r3" target="r0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="re4" value="sample == 7 &amp;&amp; rx == 1 / false start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B42318;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;" edge="1" parent="1" source="r1" target="r0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="re5" value="sample == 15 &amp;&amp; index &lt; 7 / index++" style="edgeStyle=orthogonalEdgeStyle;loopDirection=1;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;" edge="1" parent="1" source="r2" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rn" value="rdy_clr clears rdy independently. A low stop bit is discarded, but there is no framing_error output." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7D6;strokeColor=#E9C84A;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="430" y="670" width="650" height="90" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="brg-flow" name="BRG flow"><mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="bt" value="Baud-rate generator — two counter machines" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#002060;" vertex="1" parent="1"><mxGeometry x="50" y="30" width="900" height="50" as="geometry"/></mxCell><mxCell id="btx0" value="&lt;b&gt;TX COUNT&lt;/b&gt;&lt;br&gt;tx_enable = 0&lt;br&gt;tx_counter++" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9E1F2;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="190" y="260" width="290" height="150" as="geometry"/></mxCell><mxCell id="btx1" value="&lt;b&gt;TX PULSE&lt;/b&gt;&lt;br&gt;tx_counter = 0&lt;br&gt;tx_enable = 1 for one clk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFFCC;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="190" y="590" width="290" height="150" as="geometry"/></mxCell><mxCell id="bte0" value="tx_counter == TX_DIV - 1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="btx0" target="btx1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="bte1" value="next clk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="btx1" target="btx0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="brx0" value="&lt;b&gt;RX COUNT&lt;/b&gt;&lt;br&gt;rx_en = 0&lt;br&gt;rx_counter++" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E7FF;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="870" y="260" width="290" height="150" as="geometry"/></mxCell><mxCell id="brx1" value="&lt;b&gt;RX PULSE&lt;/b&gt;&lt;br&gt;rx_counter = 0&lt;br&gt;rx_en = 1 for one clk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFF99;strokeColor=#002060;strokeWidth=3;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="870" y="590" width="290" height="150" as="geometry"/></mxCell><mxCell id="bre0" value="rx_counter == RX_DIV - 1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="brx0" target="brx1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="bre1" value="next clk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0563C1;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#17233D;" edge="1" parent="1" source="brx1" target="brx0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="bn" value="Default relationship: TX_DIV = 5208 and RX_DIV = 325. At 50 MHz this is approximately 9600 baud with a 16× receive-enable cadence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7D6;strokeColor=#E9C84A;fontSize=16;fontColor=#17233D;" vertex="1" parent="1"><mxGeometry x="490" y="820" width="640" height="90" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="signal-timing" name="Signal timing"><mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1120" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Signal timing — real uart_top signal names" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#002060;" vertex="1" parent="1"><mxGeometry x="50" y="20" width="900" height="50" as="geometry"/></mxCell><mxCell id="timing-image" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=1;aspect=fixed;image=data:image/svg+xml,;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="1520" height="960" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
